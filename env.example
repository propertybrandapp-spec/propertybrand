# Copy this file to .env and fill in your real Supabase project values.
# Get these from: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Cloudflare R2 upload gateway — the Worker URL you get after running
# `wrangler deploy` from the cloudflare-worker/ folder.
VITE_R2_WORKER_URL=https://propertybrands-r2-upload.your-subdomain.workers.dev
